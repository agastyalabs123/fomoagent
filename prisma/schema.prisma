generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  startDate   Int?
  endDate     Int?
  time        String?
  location    String?
  source      String   // "solana" | "cryptoNomads" | "ethGlobal"
  category    String?  // e.g. "major", "community", "upcoming", "past"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, startDate, source])
}
